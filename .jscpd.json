{
    "threshold": 100,
    "minTokens": 50,
    "minLines": 5,
    "absolute": true,
    "reporters": ["console", "html", "json"],
    "output": ".lint-reports/jscpd",
    "gitignore": false,
    "ignore": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.cache/**",
        "**/.lint-reports/**",
        "**/.jscpd-report/**",
        "**/build/**",
        "**/coverage/**",
        "**/data/**",
        "**/*.test.ts",
        "**/*.test.js",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.glsl",
        "**/*.d.ts",
        "**/auto-gen/**",
        "**/icons/*-paths.json",
        "**/icons/*.json",
        "**/styles/auto-gen/**",
        "**/styles/tokens/**",
        "**/extracted-cache-assets/**",
        "**/main/electron/**",
        "**/main/server/data/**",
        "**/main/server/certs/**",
        "**/public/resources/**",
        "**/scripts/**",
        "**/clansocket-errors/**",
        "**/clansocket-docs/**",
        "**/clansocket-plugin/**",
        "**/main/discord/dist/**",
        "**/.git/**"
    ],
    "format": ["typescript", "javascript", "css"]
}
